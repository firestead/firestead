{
    "name": "@firestead/nuxt",
    "description": "nuxt3 module for firestead",
    "repository": "firestead/firestead",
    "keywords": [
        "nuxt",
        "nuxt-module",
        "firestead",
        "firebase"
    ],
    "version": "0.0.1",
    "type": "module",
    "license": "MIT",
    "files": [
        "dist"
    ],
    "scripts": {

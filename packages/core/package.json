        "@vercel/nft": "^0.17.0",
        "chalk": "^4.1.1",
        "consola": "^2.15.3",
        "esbuild": "^0.14.11",
        "firebase": "^9.6.3",
        "firebase-admin": "^10.0.1",
        "firebase-functions": "^3.16.0",
        "fs-extra": "^10.0.0",
        "h3": "^0.3.3",

    "keywords": [
        "nuxt",
        "nuxt-module",
        "firestead",
        "firebase"
    ],
    "version": "0.0.18",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Johannes Hof",
        "email": "johannes@disedia.com"
    },
    "files": ["dist"],
    "scripts": {
        "dev": "unbuild --stub",

{
    "name": "firestead-monorepo",
    "type": "module",
    "license": "MIT",
    "workspaces": [
        "packages/*",
        "demo"
    ],
    "scripts": {
        "build": "FORCE_COLOR=1 lerna run prepack --stream --no-prefix",
        "stub": "lerna run prepack -- --stub",
        "nuxi": "./node_modules/.bin/nuxi",
        "demo": "yarn run nuxi dev demo",
        "watch:ui": "./node_modules/windicss/cli/index.js './packages/ui/src/**/*.vue' -to ./packages/ui/src/assets/style.css --config './packages/ui/windi.config.cjs' --dev"
    },
    "resolutions": {
        "firestead": "workspace:./packages/module",
        "unbuild": "^0.5.13",
        "jiti": "^1.12.9"
    },
    "devDependencies": {
        "jiti": "^1.12.9",
        "lerna": "^4.0.0",
        "unbuild": "^0.5.13"
    },
    "packageManager": "yarn@3.1.1",
    "engines": {
        "node": "^14.16.0 || ^16.11.0 || ^17.0.0"
    }
}

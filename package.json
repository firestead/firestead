{
    "name": "firestead-monorepo",
    "type": "module",
    "license": "MIT",
    "workspaces": [
        "packages/*",
        "examples/*"
    ],
    "scripts": {
        "build": "FORCE_COLOR=1 lerna run prepack --stream --no-prefix",
        "stub": "lerna run prepack -- --stub",
        "release": "FORCE_COLOR=1 lerna run prepack -- --release && sh ./scripts/release.sh",
        "firestead": "./node_modules/.bin/firestead",
        "examples:nuxt": "yarn run firestead dev examples/nuxt",
        "examples:nuxt:build": "yarn run firestead build examples/nuxt",
        "examples:nuxt:deploy": "yarn run firestead deploy examples/nuxt",
        "watch:ui": "./node_modules/windicss/cli/index.js './packages/**/*.vue'  -to ./packages/ui/src/app/assets/style.css --config './packages/ui/windi.config.cjs' --style --dev"
    },
    "resolutions": {
        "firestead": "workspace:./packages/core",
        "@firestead/kit": "workspace:./packages/kit",
        "@firestead/console": "workspace:./packages/console",
        "@firestead/cli": "workspace:./packages/cli",
        "@firestead/nuxt": "workspace:./packages/nuxt",
        "unbuild": "^0.6.8",
        "jiti": "^1.12.14",
        "rollup": "^2.63.0",
        "firebase-admin": "^10.0.2"
    },
    "devDependencies": {
        "jiti": "^1.12.14",
        "lerna": "^4.0.0",
        "unbuild": "^0.6.8"
    },
    "packageManager": "yarn@3.1.1",
    "engines": {
        "node": "^14.16.0 || ^16.11.0 || ^17.0.0"
    }
}

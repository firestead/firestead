{
    "name": "firestead-monorepo",
    "type": "module",
    "license": "MIT",
    "workspaces": [
        "packages/kit",
        "packages/module",
        "packages/ui",
        "packages/addons/*",
        "examples/*"
    ],
    "scripts": {
        "build": "FORCE_COLOR=1 lerna run prepack --stream --no-prefix",
        "stub": "lerna run prepack -- --stub",
        "release": "FORCE_COLOR=1 lerna run prepack -- --release",
        "nuxi": "./node_modules/.bin/nuxi",
        "example:nuxt": "yarn run nuxi dev examples/nuxt",
        "watch:ui": "./node_modules/windicss/cli/index.js './packages/ui/src/**/*.vue'  -to ./packages/ui/src/app/assets/style.css --config './packages/ui/windi.config.cjs' --style --dev"
    },
    "resolutions": {
        "firestead": "workspace:./packages/module",
        "@firestead/kit": "workspace:./packages/kit",
        "@firestead/ui": "workspace:./packages/ui"
    },
    "devDependencies": {
        "jiti": "^1.12.9",
        "lerna": "^4.0.0",
        "unbuild": "^0.6.7"
    },
    "packageManager": "yarn@3.1.1",
    "engines": {
        "node": "^14.16.0 || ^16.11.0 || ^17.0.0"
    }
}
